# Drop this file at: ~/sites/base/conf.d/40k.caddy
# Then: docker exec caddy caddy reload --config /etc/caddy/Caddyfile

40k.thewheeliebois.com {
    handle_path /api/* {
        reverse_proxy 40k-api:3000
    }
    handle {
        root * /srv/40kResultsTracker/app
        encode gzip zstd
        file_server
        try_files {path} /index.html
    }
}
