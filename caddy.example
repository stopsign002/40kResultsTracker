# Drop this file at: ~/sites/base/conf.d/40k.caddy
# Then: docker exec caddy caddy reload --config /etc/caddy/Caddyfile

40k.thewheeliebois.com {
    # SSE endpoint: needs flush_interval so chunks aren't buffered;
    # `encode` (gzip/zstd) is intentionally NOT in this handler.
    handle_path /api/events {
        reverse_proxy 40k-api:3000 {
            flush_interval -1
        }
    }
    handle_path /api/* {
        reverse_proxy 40k-api:3000
    }
    handle {
        root * /srv/40kResultsTracker/app
        encode gzip zstd
        file_server
        try_files {path} /index.html
    }
}
